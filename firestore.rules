rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Reusable validation helpers
    // ============================================================
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }
    function isNonNegInt(field) {
      return field is int && field >= 0;
    }
    // True when the signed-in caller has a follower entry on the target's
    // followers subcollection (i.e. caller follows the target). Costs 1 read.
    function followsAuthor(authorUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(authorUid)/followers/$(request.auth.uid));
    }
    // True when the signed-in caller's user doc carries accountKind == "gym".
    // Costs 1 read; cache where possible.
    function callerIsGym() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('accountKind', '') == 'gym';
    }
    // True when the caller is a gym AND their subscription (trial or paid)
    // hasn't expired. Gates ad creation and article posting. Costs 1 read.
    function callerHasActiveGymSub() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
        && userData.get('accountKind', '') == 'gym'
        && (userData.get('subscriptionStatus', '') in ['trial', 'active'])
        && ('subscriptionExpiresAt' in userData)
        && userData.subscriptionExpiresAt > request.time;
    }

    // ============================================================
    // users/{uid}
    // ============================================================
    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && isString(request.resource.data.name, 1, 80)
        && isString(request.resource.data.handle, 0, 50)
        && isString(request.resource.data.location, 0, 80)
        && isString(request.resource.data.bio, 0, 500)
        && isString(request.resource.data.skill, 0, 30);

      // Owner can update any field (subject to per-field validation below).
      // Any other signed-in user may *only* touch aggregate counters used
      // by the client-side follow/rating mirror. Field-level validation
      // checks the diff (affectedKeys) rather than the full post-merge
      // document — otherwise pre-existing fields like `name` cause every
      // non-owner write to fail, since they're present in
      // request.resource.data even when not being modified.
      allow update: if isSignedIn()
        && (
          isSelf(uid)
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['followersCount', 'followingCount',
                        'ratingAverage', 'ratingCount'])
        )
        && (!('name' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.name, 1, 80)))
        && (!('handle' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.handle, 0, 50)))
        && (!('location' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.location, 0, 80)))
        && (!('bio' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.bio, 0, 500)))
        && (!('skill' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.skill, 0, 30)))
        // fcmToken moved to users/{uid}/private/profile. Reject writes to
        // the public doc so it can't be re-leaked.
        && !('fcmToken' in request.resource.data.diff(resource.data).affectedKeys())
        && (!('photoURL' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.photoURL, 0, 2048)))
        && (!('position' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.position, 0, 40)))
        && (!('education' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.education, 0, 40)))
        && (!('tosAcceptedAt' in request.resource.data.diff(resource.data).affectedKeys()) || isSelf(uid))
        && (!('isPrivate' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && request.resource.data.isPrivate is bool))
        && (!('accountKind' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.accountKind, 0, 20)))
        && (!('businessName' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.businessName, 0, 120)))
        // ein, managerFirstName, managerLastName moved to users/{uid}/private/profile.
        // Reject writes to the public doc so they can't be re-leaked.
        && !('ein' in request.resource.data.diff(resource.data).affectedKeys())
        && !('managerFirstName' in request.resource.data.diff(resource.data).affectedKeys())
        && !('managerLastName' in request.resource.data.diff(resource.data).affectedKeys())
        && (!('businessAddress' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.businessAddress, 0, 200)))
        && (!('gymCourtSize' in request.resource.data.diff(resource.data).affectedKeys()) || (isSelf(uid) && isString(request.resource.data.gymCourtSize, 0, 20)))
        // Subscription fields are server-managed. Clients cannot write
        // subscriptionStatus / trialStartedAt / subscriptionExpiresAt /
        // appStore* — Cloud Functions (validateAppStoreTransaction,
        // appStoreServerNotificationsV2, stampGymTrialOnCreate) own them.
        // The Admin SDK bypasses these rules.
        && !('subscriptionStatus' in request.resource.data.diff(resource.data).affectedKeys())
        && !('trialStartedAt' in request.resource.data.diff(resource.data).affectedKeys())
        && !('subscriptionExpiresAt' in request.resource.data.diff(resource.data).affectedKeys())
        && !('subscriptionUpdatedAt' in request.resource.data.diff(resource.data).affectedKeys())
        && !('appStoreOriginalTransactionId' in request.resource.data.diff(resource.data).affectedKeys())
        && !('appStoreProductId' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if isSelf(uid);

      // ---- users/{uid}/following/{targetUid} ----
      match /following/{targetUid} {
        allow read: if isSignedIn();
        allow create: if isSelf(uid)
          && uid != targetUid
          && isString(request.resource.data.name, 1, 80)
          && isString(request.resource.data.initials, 1, 4);
        allow delete: if isSelf(uid);
        allow update: if false;
      }

      // ---- users/{uid}/followers/{followerUid} ----
      // Mirrored client-side: the *follower* writes/deletes their own entry
      // on the target's followers subcollection. The target user cannot.
      match /followers/{followerUid} {
        allow read: if isSignedIn();
        allow create: if isSelf(followerUid)
          && followerUid != uid
          && isString(request.resource.data.name, 1, 80)
          && isString(request.resource.data.initials, 1, 4);
        allow delete: if isSelf(followerUid);
        allow update: if false;
      }

      // ---- users/{uid}/runs/{runId} ----
      // Only the owner can read/write their own run history.
      match /runs/{runId} {
        allow read: if isSelf(uid);
        allow create: if isSelf(uid)
          && isString(request.resource.data.courtId, 1, 200)
          && isString(request.resource.data.courtName, 1, 200)
          && request.resource.data.durationMinutes is int
          && request.resource.data.durationMinutes >= 0
          && request.resource.data.durationMinutes <= 24 * 60;
        allow update, delete: if isSelf(uid);
      }

      // ---- users/{uid}/notifications/{notificationId} ----
      // Personal inbox. The owner has full control. Any other signed-in
      // user may *create* a notification in this inbox (e.g. when they
      // follow this user), but cannot read or modify existing entries.
      match /notifications/{notificationId} {
        allow read, update, delete: if isSelf(uid);
        allow create: if isSelf(uid)
          || (isSignedIn()
              && isString(request.resource.data.type, 1, 40)
              && isString(request.resource.data.title, 1, 200)
              && isString(request.resource.data.body, 0, 500));
      }

      // ---- users/{uid}/private/{docId} ----
      // Owner-only storage for sensitive PII:
      //   • ein                 — federal Employer Identification Number
      //   • fcmToken            — push targeting token
      //   • managerFirstName /  — staff PII for gym accounts
      //     managerLastName
      // Nothing in this subcollection is ever readable by anyone other than
      // the owner. Cloud Functions running with the Admin SDK bypass these
      // rules and can still read for moderation / receipt validation.
      match /private/{docId} {
        allow read, write: if isSelf(uid);
      }

      // ---- users/{uid}/blocked/{targetUid} ----
      // Block list is per-user and strictly private. Only the owner can
      // read it (so blocked users can't enumerate who blocked them) and
      // only the owner can add/remove entries.
      match /blocked/{targetUid} {
        allow read, list: if isSelf(uid);
        allow create: if isSelf(uid)
          && uid != targetUid
          && request.resource.data.keys().hasOnly(['blockedAt'])
          && request.resource.data.blockedAt is timestamp;
        allow delete: if isSelf(uid);
        allow update: if false;
      }

      // ---- users/{uid}/ratings/{raterUid} ----
      // Any signed-in user can leave/update their own rating doc on another
      // user. Aggregate fields on the parent user doc are updated in the
      // same client transaction (covered by the users/update rule above).
      match /ratings/{raterUid} {
        allow read: if isSignedIn();
        allow create, update: if isSelf(raterUid)
          && raterUid != uid
          && request.resource.data.raterUid == raterUid
          && request.resource.data.ratedUid == uid
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5
          && (!('comment' in request.resource.data) || isString(request.resource.data.comment, 0, 1000))
          && (!('ballHandling' in request.resource.data)
              || (request.resource.data.ballHandling is int
                  && request.resource.data.ballHandling >= 1
                  && request.resource.data.ballHandling <= 5))
          && (!('basketballIQ' in request.resource.data)
              || (request.resource.data.basketballIQ is int
                  && request.resource.data.basketballIQ >= 1
                  && request.resource.data.basketballIQ <= 5))
          && (!('teamPlay' in request.resource.data)
              || (request.resource.data.teamPlay is int
                  && request.resource.data.teamPlay >= 1
                  && request.resource.data.teamPlay <= 5))
          && (!('toughness' in request.resource.data)
              || (request.resource.data.toughness is int
                  && request.resource.data.toughness >= 1
                  && request.resource.data.toughness <= 5));
        allow delete: if isSelf(raterUid);
      }
    }

    // ============================================================
    // courts/{courtId}
    // ============================================================
    match /courts/{courtId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(
          ['name', 'address', 'lat', 'lon', 'maxCap', 'skill', 'type',
           'playingCount', 'updatedAt', 'ratingAverage', 'ratingCount'])
        && isString(request.resource.data.name, 1, 120)
        && isString(request.resource.data.address, 0, 200)
        && request.resource.data.lat is number
        && request.resource.data.lon is number
        && request.resource.data.maxCap is int
        && request.resource.data.maxCap >= 0 && request.resource.data.maxCap <= 500;

      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['playingCount', 'updatedAt', 'name', 'address',
                      'lat', 'lon', 'maxCap', 'skill', 'type',
                      'ratingAverage', 'ratingCount'])
        && (
          !('playingCount' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.playingCount == (resource.data.get('playingCount', 0) + 1)
              || request.resource.data.playingCount == (resource.data.get('playingCount', 0) - 1))
        );

      allow delete: if false;

      // ---- courts/{courtId}/checkIns/{uid} ----
      match /checkIns/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isSelf(uid)
          && request.resource.data.uid == uid
          && isString(request.resource.data.displayName, 1, 80)
          && isString(request.resource.data.initials, 1, 4);
        allow delete: if isSelf(uid);
      }

      // ---- courts/{courtId}/ratings/{raterUid} ----
      match /ratings/{raterUid} {
        allow read: if isSignedIn();
        allow create, update: if isSelf(raterUid)
          && request.resource.data.raterUid == raterUid
          && request.resource.data.courtId == courtId
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5;
        allow delete: if isSelf(raterUid);
      }
    }

    // ============================================================
    // feedPosts/{postId}
    // ============================================================
    // Posts written via FeedRepository carry the author's `isPrivate` flag
    // captured at post time (denormalized for cheap server-side filtering).
    // A post is readable when ANY of:
    //   * authorIsPrivate is missing or false (public post), OR
    //   * the caller is the author, OR
    //   * the caller follows the author (1 read via exists()).
    match /feedPosts/{postId} {
      allow read: if isSignedIn()
        && (
          !('authorIsPrivate' in resource.data)
          || resource.data.authorIsPrivate == false
          || resource.data.authorId == request.auth.uid
          || followsAuthor(resource.data.authorId)
        );

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && isString(request.resource.data.body, 1, 2000)
        && isString(request.resource.data.authorName, 1, 80)
        && isString(request.resource.data.authorInitials, 1, 4)
        && request.resource.data.likes is int
        && request.resource.data.comments is int
        && request.resource.data.createdAt is timestamp
        && (!('authorIsPrivate' in request.resource.data)
            || request.resource.data.authorIsPrivate is bool)
        // Only gyms with an active subscription can publish ads. Non-gym
        // callers must omit the field or set it to false.
        && (!('isAd' in request.resource.data)
            || request.resource.data.isAd == false
            || (request.resource.data.isAd == true && callerHasActiveGymSub()));

      // Only the author can update their own post, and only the mutable
      // content/counter fields. authorId, authorIsPrivate, authorIsGym,
      // isAd, createdAt, etc. are locked once written so a user can't
      // sneak an ad in via update or change attribution.
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['body', 'likes', 'comments', 'moodLabel']);

      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;
    }

    // ============================================================
    // articles/{articleId}
    // ============================================================
    // Local news authored by gym/business accounts. Surfaces in the News
    // tab of the feed. Any signed-in user can read; only gyms can create.
    match /articles/{articleId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && callerHasActiveGymSub()
        && request.resource.data.authorId == request.auth.uid
        && isString(request.resource.data.title, 1, 200)
        && isString(request.resource.data.body, 1, 4000)
        && isString(request.resource.data.authorName, 1, 120)
        && request.resource.data.createdAt is timestamp
        // url is optional. When present it must be http/https only —
        // rejects javascript:, data:, file:, custom schemes etc.
        && (!('url' in request.resource.data)
            || (isString(request.resource.data.url, 0, 2048)
                && request.resource.data.url.matches('^https?://[^/].*')));

      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'body', 'url']);
      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;
    }

    // ============================================================
    // gymTrialClaims/{appleUserIdentifier}  (server-only)
    // appStoreLinks/{originalTransactionId} (server-only)
    // ============================================================
    // Subscription bookkeeping owned exclusively by Cloud Functions
    // (stampGymTrialOnCreate, validateAppStoreTransaction). Clients must
    // never read or write these — the Admin SDK bypasses the deny.
    match /gymTrialClaims/{appleUserIdentifier} {
      allow read, write: if false;
    }
    match /appStoreLinks/{originalTransactionId} {
      allow read, write: if false;
    }

    // ============================================================
    // reports/{reportId}
    // ============================================================
    // User-submitted moderation reports. Required by App Store Guideline 1.2.
    // Write-only from the client — only moderators (out-of-band, via Cloud
    // Functions / Firebase Console with admin SDK) can read or update.
    match /reports/{reportId} {
      allow read, list: if false;
      allow update, delete: if false;

      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && isString(request.resource.data.entityType, 1, 40)
        && isString(request.resource.data.entityId, 1, 200)
        && isString(request.resource.data.reason, 1, 40)
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && (!('reportedUid' in request.resource.data)
            || isString(request.resource.data.reportedUid, 0, 128))
        && (!('details' in request.resource.data)
            || isString(request.resource.data.details, 0, 2000));
    }

    // ============================================================
    // threads/{threadId}
    // ============================================================
    match /threads/{threadId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ---- threads/{threadId}/messages/{messageId} ----
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;

        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants
          && isString(request.resource.data.text, 1, 2000);

        allow update, delete: if false;
      }
    }

    // ============================================================
    // Default deny — any collection not explicitly matched above is
    // unreachable. Add a `match` block before deploying new features.
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
